{
  "manifest_version": 2,
  "name": "Tab URL & Title Copier",
  "version": "1.2",
  "description": "Copies open tab titles and URLs to the clipboard with filtering and YouTube URL cleaning.",
  "update_url": "https://raw.githubusercontent.com/multivac2x/addon-tab-url-and-title-copier/main/updates.xml",
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_security_policy": "script-src 'self'; object-src 'none'",
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Copy Tab Titles & URLs",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-url-title-copier@multivac2x.github.io",
      "data_collection_permissions": {
        "required": true,
        "cookies": false,
        "tracking": false,
        "history": false,
        "passwords": false,
        "privateBrowsing": false
      }
    }
  }
}