{
  "manifest_version": 2,
  "name": "Tab URL & Title Copier",
  "version": "1.2",
  "description": "Copies open tab titles and URLs to the clipboard with filtering and YouTube URL cleaning.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_security_policy": "script-src 'self'; object-src 'none'",
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Copy Tab Titles & URLs",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}