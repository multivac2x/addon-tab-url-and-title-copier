{
  "manifest_version": 2,
  "name": "Tab URL Copier",
  "version": "1.0",
  "description": "Copies all open tab URLs to the clipboard.",
  "permissions": [
    "tabs",
    "<all_urls>"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Copy Tab URLs",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}